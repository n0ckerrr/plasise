# ============================================================================
# PLASISE BACKEND - ENVIRONMENT VARIABLES
# Copiar este archivo como .env y configurar con valores reales
# ============================================================================

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-to-another-random-secret-key

# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=plasise_user
MYSQL_PASSWORD=your_secure_password_here
MYSQL_DATABASE=plasise

# Email Configuration (Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=noreply@plasise.com

# Redis Configuration (optional, for cache and sessions)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration (optional, for async tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,https://plasise.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Application URL (for emails, etc.)
APP_URL=https://plasise.com
FRONTEND_URL=https://plasise.com

# File Storage (local, s3, etc.)
STORAGE_TYPE=local
# If using S3:
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=eu-west-1
